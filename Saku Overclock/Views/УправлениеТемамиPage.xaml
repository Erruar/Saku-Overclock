<Page
    x:Class="Saku_Overclock.Views.УправлениеТемамиPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
    </Page.Resources>

    <Grid Margin="-48,0,-48,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MaxWidth="1200">

            <!-- Навигация -->
            <BreadcrumbBar x:Name="PageBreadcrumb"
                           Margin="-1,-95,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           ItemClicked="PageBreadcrumb_ItemClicked">
                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" FontSize="24"/>
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>

            <!-- Сбросить все темы (справа сверху) -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-87,4,0"
                    Background="Transparent" BorderThickness="0"
                    Click="ResetAllThemes_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE777;" FontSize="15"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Сбросить все темы" FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Button>

            <!-- Основной контент -->
            <Grid Margin="-1,-30,-6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="214" MinWidth="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Слева: карточки тем -->
                <Grid Grid.Column="0" Padding="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Margin="0,-2,-5,0"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Enabled">
                        <StackPanel x:Name="ThemeCardsPanel"
                                    Orientation="Vertical"
                                    Margin="3,0,9,0"/>
                    </ScrollViewer>

                    <Button Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            CornerRadius="14"
                            Margin="2,10,2,10"
                            Click="AddTheme_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Добавить" FontSize="13" VerticalAlignment="Center"/>
                            <FontIcon Glyph="&#xE710;" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ═══ RIGHT: theme settings ═══ -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,-2,-13,0">
                    <StackPanel Margin="18,0,31,10" Orientation="Vertical">

                        <!-- InfoBar for built-in themes 0–2 -->
                        <InfoBar x:Name="BuiltInThemeInfoBar"
                                 IsOpen="False" CornerRadius="15"
                                 IsClosable="False"
                                 Severity="Informational"
                                 Title="Стандартная тема"
                                 Message="Эта тема встроенная и не может быть изменена."
                                 Margin="0,4,0,0"/>

                        <!-- Edit panel for custom themes -->
                        <StackPanel x:Name="ThemeEditPanel" Visibility="Collapsed">
                            <TextBlock Margin="0,0,0,0" x:Uid="ThemeAdvanced" />
                            <!-- Color intensity -->
                            <Grid Visibility="{Binding ElementName=ThemeOpacitySlider, Path=Visibility}"
                                  Margin="0,18,0,0" Height="60" HorizontalAlignment="Stretch" CornerRadius="15,15,0,0"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE890;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,0,0,0"
                                               x:Uid="ThemeOpacity" FontSize="14" Text="Интенсивность цвета" />
                                    <TextBlock Margin="50,2,0,0" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="ThemeOpacityDesc" Text="Изменяет прозрачность фонового изображения" />
                                </Grid>
                                <Slider Margin="0,0,26,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                                        x:Name="ThemeOpacitySlider" Width="131"
                                        StepFrequency="0.1" Minimum="0.0" Maximum="1.0" Value="0.5"
                                        ValueChanged="ThemeColorIntensity_ValueChanged"/>
                            </Grid>

                            <!-- Mask opacity -->
                            <Grid Visibility="{Binding ElementName=ThemeMaskOpacitySlider, Path=Visibility}"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE727;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,0,0,0"
                                               x:Uid="ThemeMaskOpacity" FontSize="14" Text="Интенсивность размытия фона" />
                                    <TextBlock Margin="50,2,0,0" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="ThemeMaskOpacityDesc" Text="Изменяет силу размытия фонового изображения" />
                                </Grid>
                                <Slider Margin="0,0,26,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                                        x:Name="ThemeMaskOpacitySlider" Width="131"
                                        StepFrequency="0.1" Minimum="0.0" Maximum="1.0" Value="0.5"
                                        ValueChanged="ThemeBackgroundMaskOpacity_ValueChanged"/>
                            </Grid>

                            <!-- Theme type light/dark -->
                            <Grid Visibility="{Binding ElementName=ThemeTypeComboBox, Path=Visibility}"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE793;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,0,0,0"
                                               x:Uid="ThemeLight" FontSize="14" Text="Тип темы" />
                                    <TextBlock Margin="50,2,0,0" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="ThemeLightDesc" Text="Устанавливает тип темы: светлая или тёмная" />
                                </Grid>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,-6,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="120"
                                              Margin="{StaticResource XSmallTopMargin}" CornerRadius="15"
                                              SelectedIndex="1" x:Name="ThemeTypeComboBox"
                                              SelectionChanged="ThemeType_SelectionChanged">
                                        <ComboBoxItem x:Uid="Settings_Theme_Dark" Content="Тёмная" />
                                        <ComboBoxItem x:Uid="Settings_Theme_Light" Content="Светлая" />
                                    </ComboBox>
                                </Grid>
                            </Grid>

                            <!-- Custom background toggle -->
                            <Grid Visibility="{Binding ElementName=ThemeCustomBgSwitch, Path=Visibility}"
                                  PointerPressed="ToggleThemeCustomBgSwitch_PointerPressed"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE8B9;"/>
                                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                               x:Uid="ThemeCustomBg">Использовать свой фон</TextBlock>
                                </StackPanel>
                                <ToggleSwitch VerticalAlignment="Center" HorizontalAlignment="Right"
                                              Margin="0,0,-97,0" OffContent="" OnContent=""
                                              x:Name="ThemeCustomBgSwitch" Visibility="Collapsed"
                                              Toggled="ThemeCustomBackground_Toggled"/>
                            </Grid>

                            <!-- Change background button -->
                            <Grid Visibility="{Binding ElementName=ThemeBgBtn, Path=Visibility}"
                                  PointerPressed="OpenSelectThemeBackground_Click"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE72A;"/>
                                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                               x:Uid="ThemeChangeBgText">Установите свой фон</TextBlock>
                                </StackPanel>
                                <Button VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Margin="0,0,16,0" Visibility="{Binding ElementName=ThemeCustomBgSwitch, Path=Visibility}"
                                        Shadow="{StaticResource SharedShadow}" Translation="0,0,20"
                                        Click="OpenSelectThemeBackground_Click"
                                        x:Name="ThemeBgBtn" Width="151"
                                        Style="{ThemeResource AccentButtonStyle}" CornerRadius="15">
                                    <TextBlock x:Uid="ThemeChangeBgText" FontWeight="SemiBold"
                                               Text="Change background"/>
                                </Button>
                            </Grid>

                            <!-- Reset to defaults (last row, rounded bottom) -->
                            <Grid CornerRadius="0,0,15,15" Margin="0,2,0,0" Height="60"
                                  HorizontalAlignment="Stretch" PointerPressed="ResetCurrentTheme_Click"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left"
                                              Margin="17,0,0,-18" Glyph="&#xE7A6;"/>
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center"
                                               Margin="50,0,0,0" FontSize="14"
                                               Text="По умолчанию"/>
                                    <TextBlock Grid.Row="1" Margin="50,2,0,0" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               Text="Сбросить все параметры темы на стандартные"/>
                                </Grid>
                                <Button VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Margin="0,0,16,0"
                                        Shadow="{StaticResource SharedShadow}" Translation="0,0,20"
                                        Width="120" Style="{ThemeResource AccentButtonStyle}"
                                        CornerRadius="15" Click="ResetCurrentTheme_Click">
                                    <TextBlock FontWeight="SemiBold" Text="Сбросить"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Placeholder when nothing selected -->
                        <TextBlock x:Name="NoSelectionText"
                                   Visibility="Collapsed"
                                   Text="Выберите тему для редактирования"
                                   HorizontalAlignment="Center" Margin="0,48,0,0"
                                   FontSize="15"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Top divider line -->
        <Border VerticalAlignment="Top" Margin="-1,-44,0,0"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                Height="2" HorizontalAlignment="Stretch"/>
    </Grid>
</Page>