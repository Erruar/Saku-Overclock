<Page
    x:Class="Saku_Overclock.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Saku_Overclock.Helpers"
    mc:Ignorable="d">
    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <helpers:HexColorInverterConverter x:Key="HexColorInverterConverter" />
        <helpers:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <helpers:BooleanToGlyphConverter x:Key="BooleanToGlyphConverter" />
        <helpers:BooleanInverterConverter x:Key="BooleanInverterConverter" />
        <helpers:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
    </Page.Resources>

    <Grid Margin="-48,0,-48,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MaxWidth="1200">
            <TextBlock x:Uid="Settings_Name" x:Name="SettingsName" Text="Настройки программы" FontSize="24" Margin="-1,-95,0,0" />
            <Pivot Margin="-10,-110,-6,0" Loaded="PivotSettings_Loaded">
                <PivotItem>
                    <PivotItem.Header>
                        <TextBlock x:Uid="Settings_Pivot_Behaviour" Margin="0,0,0,-7" FontSize="14" Text="Behaviour" />
                    </PivotItem.Header>
                    <ScrollViewer Margin="-1,-2,-13,0">
                        <StackPanel Orientation="Vertical" Margin="0,0,13,0">
                            <StackPanel.ChildrenTransitions>
                                <TransitionCollection>
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </StackPanel.ChildrenTransitions>
                            <TextBlock Margin="0,25,0,0" x:Uid="Settings_AppBeh">Поведение приложения</TextBlock>
                            <Grid Margin="0,18,0,0" Height="60" HorizontalAlignment="Stretch" CornerRadius="15,15,0,0"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE7E8;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_AppStart" FontSize="14" Text="Параметры запуска" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Preset_AppStartDesc"
                                               Text="Запускать программу при входе в систему" />
                                </Grid>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,-6,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="190"
                                              Margin="{StaticResource XSmallTopMargin}" CornerRadius="15"
                                              SelectedIndex="0" x:Name="AutoStartComboBox"
                                              SelectionChanged="AutoStartComboBox_SelectionChanged">
                                        <ComboBoxItem x:Uid="Settings_Start_Nothing" Content="Ничего не делать" />
                                        <ComboBoxItem x:Uid="Settings_Start_Boot" Content="Автостарт с системой" />
                                        <ComboBoxItem x:Uid="Settings_Start_MiniBoot" Content="Автостарт в трее" />
                                    </ComboBox>
                                </Grid>
                            </Grid>
                            <Grid PointerPressed="OpenReapplyOptions_Click"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE768;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_ApplyPage" FontSize="14" Text="Параметры применения" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="Settings_ApplyPageDesc" Text="Настройка применения параметров с запуском программы" />
                                </Grid>
                                <Button VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"
                                        Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" Width="190" x:Uid="ThemeManagerButton"
                                        Click="OpenReapplyOptions_Click"
                                        CornerRadius="15" Content="Перейти"/>
                            </Grid>
                            <Grid PointerPressed="ToggleTheSwitchByTag" Tag="AppHideToTray" Margin="0,2,0,0"
                                  Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE92C;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_AppHide" FontSize="14" Text="Скрывать в трей" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Preset_AppHideDesc" Text="Скрывать программу в трей при закрытии" />
                                </Grid>
                                <ToggleSwitch VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,-97,0"
                                              OffContent="" OnContent="" x:Name="AppHideToTray"
                                              Toggled="AppHideToTray_OnToggled" />
                            </Grid>
                            <Grid PointerPressed="ToggleTheSwitchByTag" Tag="AutoCheckUpdates" CornerRadius="0,0,15,15"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE895;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_Auto_Updates" FontSize="14" Text="Проверять обновления" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Settings_Auto_UpdatesDesc"
                                               Text="Уведомлять о выходе новых версий при запуске" />
                                </Grid>
                                <ToggleSwitch VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,-97,0"
                                              OffContent="" OnContent="" x:Name="AutoCheckUpdates"
                                              Toggled="AutoCheckUpdates_Click" />
                            </Grid>

                            <TextBlock Margin="0,20,0,0" x:Uid="Settings_Personalization" />
                            <Grid Margin="0,18,0,0" Height="60" HorizontalAlignment="Stretch" CornerRadius="15,15,0,0"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE790;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_Theme" FontSize="14" Text="Цветовая тема" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Settings_ThemeDesc" Text="Выберите цветовую тему для приложения" />
                                </Grid>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="190"
                                              x:Name="ThemeComboBox" SelectionChanged="ThemesComboBox_SelectionChanged"
                                              CornerRadius="15">
                                        <ComboBoxItem Content="System default" />
                                        <ComboBoxItem Content="Light" />
                                        <ComboBoxItem Content="Dark" />
                                        <ComboBoxItem Content="Candy clouds" />
                                        <ComboBoxItem Content="Neon glow" />
                                        <ComboBoxItem Content="Raspberry" />
                                        <ComboBoxItem Content="Desert lineage" />
                                    </ComboBox>
                                </Grid>
                            </Grid>
                            <Grid CornerRadius="0,0,15,15" PointerPressed="OpenThemeManager_Click"
                                  Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE762;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="ThemeManager" FontSize="14" Text="Управление темами" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="ThemeManagerDesc" Text="Настройка, управление и создание тем" />
                                </Grid>
                                <Button VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"
                                        Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" Width="190" x:Uid="ThemeManagerButton"
                                        Click="OpenThemeManager_Click"
                                        CornerRadius="15" Content="Перейти"/>
                            </Grid>

                            <TextBlock Margin="0,18,0,0" x:Uid="Settings_Keybinds" Text="Сочетания клавиш" />

                            <Grid PointerPressed="ToggleTheSwitchByTag" Tag="EnableKeybindingsSetting"
                                  x:Name="EnableKeybindingsSettingGrid"
                                  Margin="0,18,0,0" Height="60" HorizontalAlignment="Stretch" CornerRadius="15, 15,0,0"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE92E;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_Keybinds_Enable" FontSize="14" Text="Использовать комбинации клавиш" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" x:Uid="Settings_Keybinds_Desc" Text="Управление функциями приложения с помощью клавиатуры без переключения окон" />
                                </Grid>
                                <ToggleSwitch IsOn="True" VerticalAlignment="Center" HorizontalAlignment="Right"
                                              Margin="0,0,-97,0" OffContent="" OnContent=""
                                              x:Name="EnableKeybindingsSetting" Toggled="EnableKeybinds_Toggled" />
                            </Grid>
                            <Grid Background="{ThemeResource ControlStrokeColorDefaultBrush}" x:Name="KeybindingsGrid"
                                  Margin="0,2,0,10" CornerRadius="0,0,15,15" HorizontalAlignment="Stretch" Height="188">
                                <Grid.Resources>
                                    <Storyboard x:Name="CollapseStoryboard">
                                        <DoubleAnimation Storyboard.TargetName="KeybindingsGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0" Duration="0:0:0.1" />
                                    </Storyboard>

                                    <Storyboard x:Name="ExpandStoryboard">
                                        <DoubleAnimation Storyboard.TargetName="KeybindingsGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </Grid.Resources>
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition MinWidth="200" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Margin="53,0,0,0" Grid.Row="0" Grid.Column="0"
                                           x:Uid="Settings_Keybinds_Elements_Custom"
                                           Text="Switch between custom user presets" />
                                <Button Grid.Row="0" Grid.Column="1" Margin="0,0,30,0" Background="Transparent"
                                        BorderBrush="Transparent"
                                        CornerRadius="4" Height="45" HorizontalAlignment="Right">
                                    <Button.RenderTransform>
                                        <ScaleTransform CenterY="22" ScaleX="0.9" ScaleY="0.9" />
                                    </Button.RenderTransform>
                                    <StackPanel Margin="-5,-4,-5,-5" HorizontalAlignment="Stretch"
                                                Orientation="Horizontal">
                                        <Border CornerRadius="10" HorizontalAlignment="Left" Width="50"
                                                Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Ctrl"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Alt"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="W"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <TextBlock FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Margin="53,0,0,0" Grid.Row="1" Grid.Column="0"
                                           x:Uid="Settings_Keybinds_Elements_Premaded"
                                           Text="Switch between premade user presets" />
                                <Button Grid.Row="1" Grid.Column="1" Margin="0,0,30,0" Background="Transparent"
                                        BorderBrush="Transparent"
                                        CornerRadius="4" Height="45" HorizontalAlignment="Right">
                                    <Button.RenderTransform>
                                        <ScaleTransform CenterY="22" ScaleX="0.9" ScaleY="0.9" />
                                    </Button.RenderTransform>
                                    <StackPanel Margin="-5,-4,-5,-5" HorizontalAlignment="Stretch"
                                                Orientation="Horizontal">
                                        <Border CornerRadius="10" HorizontalAlignment="Left" Width="50"
                                                Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Ctrl"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Alt"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="P"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <TextBlock FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Margin="53,0,0,0" Grid.Row="2" Grid.Column="0"
                                           x:Uid="Settings_Keybinds_Elements_RTSS"
                                           Text="Switch RTSS Overlay state with overlay alert" />
                                <Button Grid.Row="2" Grid.Column="1" Margin="0,0,30,0" Background="Transparent"
                                        BorderBrush="Transparent"
                                        CornerRadius="4" Height="45" HorizontalAlignment="Right">
                                    <Button.RenderTransform>
                                        <ScaleTransform CenterY="22" ScaleX="0.9" ScaleY="0.9" />
                                    </Button.RenderTransform>
                                    <StackPanel Margin="-5,-4,-5,-5" HorizontalAlignment="Stretch"
                                                Orientation="Horizontal">
                                        <Border CornerRadius="10" HorizontalAlignment="Left" Width="50"
                                                Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Ctrl"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="Alt"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                        <Border CornerRadius="10" Margin="2,0,0,0" HorizontalAlignment="Left"
                                                Width="40" Height="21"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="R"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="14" />
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </PivotItem>
                <PivotItem>
                    <PivotItem.Header>
                        <TextBlock x:Uid="Settings_Pivot_Monitoring" Margin="0,0,0,-7" FontSize="14" Text="Monitoring" />
                    </PivotItem.Header>
                    <ScrollViewer Margin="-1,-2,-13,0">
                        <StackPanel Margin="0,3,13,10" Orientation="Vertical">
                            <TextBlock Margin="0,25,0,0" x:Uid="Settings_ni_Icon" />

                            <Grid x:Name="SettingsNiIconsGrid" x:Uid="Settings_ni_Traymon_Desc"
                                  PointerPressed="ToggleTheSwitchByTag" Tag="TrayMonIconsEnabled" Margin="0,18,0,0"
                                  Height="60" HorizontalAlignment="Stretch" CornerRadius="15,15,0,0"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE735;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               x:Uid="Settings_ni_Traymon" FontSize="14"
                                               Text="Включить мониторинг в трее?" />
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Preset_TrayMonDesc" Text="Мониторинг показателей в трее" />
                                </Grid>
                                <ToggleSwitch x:Uid="Settings_ni_Traymon_Desc" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" Margin="0,0,-97,0" OffContent="" OnContent=""
                                              x:Name="TrayMonIconsEnabled" Toggled="TrayMonIconsEnabled_Toggled" />
                            </Grid>
                            <Grid Visibility="{Binding ElementName=NiIconComboboxElements, Path=Visibility}"
                                  Margin="0,2,0,0" Height="50" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE9F5;" />
                                    <TextBlock x:Name="SettingsNiIconsElement" VerticalAlignment="Center"
                                               Margin="16,0,0,0" x:Uid="Settings_ni_Elements">
                                        Выберите элемент для настройки
                                    </TextBlock>
                                </StackPanel>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="151"
                                              x:Name="NiIconComboboxElements"
                                              SelectionChanged="TrayMonIconElements_SelectionChanged" CornerRadius="15" />
                                </Grid>
                            </Grid>
                            <Grid Visibility="{Binding ElementName=SettingsNiAddElement, Path=Visibility}"
                                  PointerPressed="AddTrayMonIcon_Click" Margin="0,2,0,0" Height="50"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE710;" />
                                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                               x:Uid="Settings_ni_Add_Element">
                                        Добавить элемент
                                    </TextBlock>
                                </StackPanel>
                                <Button VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"
                                        Shadow="{StaticResource SharedShadow}" Translation="0,0,20"
                                        x:Name="SettingsNiAddElement" Click="AddTrayMonIcon_Click" Width="151"
                                        Style="{ThemeResource AccentButtonStyle}" CornerRadius="15">
                                    <TextBlock FontWeight="SemiBold" x:Uid="Settings_ni_Add_Element" Text="Add element" />
                                </Button>
                            </Grid>
                            <Grid x:Uid="Settings_ni_EnabledElement_Desc"
                                  Visibility="{Binding ElementName=IsTrayMonIconShowing, Path=Visibility, FallbackValue=Collapsed}"
                                  PointerPressed="ToggleTheSwitchByTag" Tag="IsTrayMonIconShowing" Margin="0,2,0,0"
                                  Height="50" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                                  x:Name="SettingsNiEnabledElementGrid">
                                <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE7B3;" />
                                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                               x:Uid="Settings_ni_EnabledElement">
                                        Отображать в трее
                                    </TextBlock>
                                </StackPanel>
                                <ToggleSwitch x:Uid="Settings_ni_EnabledElement_Desc" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" Margin="0,0,-97,0" OffContent="" OnContent=""
                                              x:Name="IsTrayMonIconShowing" Toggled="IsTrayMonIconShowing_Toggled" />
                            </Grid>
                            <StackPanel Visibility="Collapsed" x:Name="NiIconStackPanel">
                                <StackPanel.ChildrenTransitions>
                                    <TransitionCollection>
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </StackPanel.ChildrenTransitions>
                                <Grid Margin="0,2,0,0" Height="50" HorizontalAlignment="Stretch"
                                      Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE8C4;" />
                                        <TextBlock Visibility="Collapsed" x:Name="SettingsNiContextMenu"
                                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                                   x:Uid="Settings_ni_ContextMenu">
                                            Контекстное меню
                                        </TextBlock>
                                    </StackPanel>
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                          Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                        <ComboBox SelectedIndex="0" Style="{ThemeResource AcrylicComboBoxStyle}"
                                                  Width="151" x:Name="NiIconCombobox"
                                                  SelectionChanged="NiIconContextMenuType_SelectionChanged"
                                                  CornerRadius="15">
                                            <ComboBoxItem x:Uid="Settings_ni_Context_Disabled" Content="Disabled" />
                                            <ComboBoxItem x:Uid="Settings_ni_Context_Base" Content="Base title" />
                                            <ComboBoxItem x:Uid="Settings_ni_Context_Extended" Content="Extended title" />
                                        </ComboBox>
                                    </Grid>
                                </Grid>
                                <Grid PointerPressed="ShowTrayMonIconColorPickerFlyout_PointerPressed"
                                      Margin="0,2,0,0" Height="50" HorizontalAlignment="Stretch"
                                      Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                        <FontIcon Glyph="&#xEF3C;" />
                                        <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                                   x:Uid="Settings_ni_Color_Picker_Desc">
                                            Изменить цвет иконки элемента
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Shadow="{StaticResource SharedShadow}" Translation="0,0,20"
                                            x:Name="SettingsNiColorPicker"
                                            VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"
                                            Width="151" Style="{ThemeResource AccentButtonStyle}" CornerRadius="15">
                                        <TextBlock x:Uid="Settings_ni_Color_Picker" FontWeight="SemiBold"
                                                   Text="Color picker" />
                                        <Button.Flyout>
                                            <Flyout>
                                                <Grid>
                                                    <ColorPicker ColorSpectrumShape="Box"
                                                                 Color="#FACAFA"
                                                                 ColorChanged="ChangeTrayMonIconColor_ColorChanged"
