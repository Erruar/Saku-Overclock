<Page
    x:Class="Saku_Overclock.Views.ГлавнаяPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Saku_Overclock.ViewModels" xmlns:scott="using:ScottPlot.WinUI"
    d:DataContext="{d:DesignInstance Type=viewmodels:ГлавнаяViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <Button x:Name="HiddenButton" Visibility="Collapsed"/>
        <Style TargetType="ToggleButton" BasedOn="{StaticResource ActiveButton}"/>
        <SolidColorBrush x:Name="SecondText" Color="{ThemeResource TextFillColorSecondary}"/>
    </Page.Resources>
    <Grid Margin="-48,-65,-50,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MaxWidth="1200">
        <TeachingTip x:Name="MainTeach" IsOpen="False">
            <StackPanel Orientation="Vertical">
                <TextBlock TextWrapping="Wrap" x:Name="MainAdditionalInfoDesc" Text="Информация об устройстве"/>
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" x:Name="MainAdditionalInfo1Desc" Text="Модель:"/>
                    <TextBlock Margin="5,0,0,0" TextWrapping="Wrap" x:Name="MainAdditionalInfo1Name"/>
                </StackPanel>
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" x:Name="MainAdditionalInfo2Desc" Text="Производитель:"/>
                    <TextBlock Margin="5,0,0,0" TextWrapping="Wrap" x:Name="MainAdditionalInfo2Name"/>
                </StackPanel>
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" x:Name="MainAdditionalInfo3Desc" Text="Версия BIOS:"/>
                    <TextBlock Margin="5,0,0,0" TextWrapping="Wrap" x:Name="MainAdditionalInfo3Name"/>
                </StackPanel>
            </StackPanel>
        </TeachingTip>
        <TeachingTip x:Name="ApplyTeach" IsOpen="False"/>
        <StackPanel Orientation="Horizontal" Margin="0,-30,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock FontSize="24" Text="Saku Overclock" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        </StackPanel>
        <Grid HorizontalAlignment="Stretch" Margin="0,20,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="525"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition MaxHeight="545"/>
                <RowDefinition Height="0.12"/>
            </Grid.RowDefinitions>
            <Grid Grid.Column="0" Margin="0,0,7,5" CornerRadius="16" Shadow="{StaticResource SharedShadow}" Translation="0,0,20" Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                <Grid.Transitions>
                    <TransitionCollection>
                        <RepositionThemeTransition/>
                    </TransitionCollection>
                </Grid.Transitions>
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition/>
                    </TransitionCollection>
                </Grid.ChildrenTransitions>
                <TextBlock Margin="14,16,0,0" FontSize="17" x:Uid="Main_DeviceInfo" Text="Информация об устройстве"/>
                <Grid Margin="0,20,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MaxHeight="270"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,33,0,27">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition MaxWidth="260"/>
                            <ColumnDefinition MaxWidth="227"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="10,0,0,0" CornerRadius="20" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                              x:Name="LogoPlacer" Tag="1" PointerPressed="TooltipPlacer_PointerPressed">
                            <Border>
                                <Border.Background>
                                    <ImageBrush ImageSource="ms-appx:///Assets/Ryzen-Logo.png" Stretch="Fill"/>
                                </Border.Background>
                            </Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="10,-20,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="Ryzen 9 8945HS \w Radeon 890M" x:Name="InfoCpuName" TextWrapping="Wrap"/>
                                    <TextBlock>
                                        <Run FontWeight="SemiBold" FontSize="24" Text="8" x:Name="InfoCpuCores"/>
                                        <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">C</Run>
                                        <Run FontWeight="SemiBold" FontSize="24" Text="16" x:Name="InfoCpuThreads"/>
                                        <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">T</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <Grid Grid.Column="1" Margin="10,0,0,0" CornerRadius="20" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                              x:Name="TemperaturePlacer" Tag="2" PointerPressed="TooltipPlacer_PointerPressed">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="10,-20,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                <TextBlock x:Uid="Main_CpuTemp" Text="Температура процессора" TextWrapping="Wrap"/>
                                <TextBlock>
                                    <Run FontWeight="SemiBold" FontSize="24" x:Name="IndicatorsTemp" Text="43"/>
                                    <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">C</Run>
                                </TextBlock>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <scott:WinUIPlot x:Name="TemperaturePlot" 
                         Margin="-25,-40,-25,0" 
                         Background="Transparent"/>
                            </Grid>
                        </Grid>
                        <Grid Grid.Column="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="10,0,10,5" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                      x:Name="UsabilityPlacer" Tag="3" PointerPressed="TooltipPlacer_PointerPressed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="10,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                        <TextBlock x:Uid="Main_CpuLoad" Text="Загрузка процессора" TextWrapping="Wrap"/>
                                        <TextBlock>
                                            <Run FontWeight="SemiBold" FontSize="24" x:Name="IndicatorsBusy" Text="70"/>
                                            <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">%</Run>
                                        </TextBlock>
                                    </StackPanel>
                                    <Grid Grid.Column="1" Margin="-10,0,0,0">
                                        <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Glyph="&#xE94C;"/>
                                    </Grid>
                                </Grid>
                                <Grid Grid.Row="1" Margin="10,5,10,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                      x:Name="FrequencyPlacer" Tag="4" PointerPressed="TooltipPlacer_PointerPressed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                        <TextBlock x:Uid="Main_CpuFreq" Text="Частота процессора" TextWrapping="Wrap"/>
                                        <TextBlock>
                                            <Run FontWeight="SemiBold" FontSize="24" x:Name="IndicatorsFreq" Text="5.0"/>
                                            <Run FontWeight="Medium" x:Uid="infoAGHZRun" Foreground="{ThemeResource TextFillColorSecondary}">GHz</Run>
                                        </TextBlock>
                                    </StackPanel>
                                    <Grid Grid.Column="1">
                                        <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Glyph="&#xECAD;"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,-23,0,5">
                        <ScrollViewer Margin="10,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="75"/>
                                    <RowDefinition Height="47"/>
                                    <RowDefinition Height="75"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" VerticalAlignment="Stretch" Margin="-10,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition MaxHeight="75"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Row="0" Grid.Column="0" Margin="10,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                          x:Name="RamPlacer" Tag="5" PointerPressed="TooltipPlacer_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="10,1,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                            <TextBlock x:Uid="Main_RamUsage" Text="RAM Usage" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Run FontWeight="SemiBold" FontSize="18" x:Name="IndicatorsRam" Text="7.6"/>
                                                <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">GB</Run>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    <Grid Grid.Row="0" Grid.Column="1" Margin="5,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                          x:Name="PowerPlacer" Tag="6" PointerPressed="TooltipPlacer_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="10,1,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                            <TextBlock x:Uid="Main_RealPower" Text="Real power" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1" Margin="-10,0,0,0">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Run FontWeight="SemiBold" FontSize="18" x:Name="IndicatorsFast" Text="70"/>
                                                <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">W</Run>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    <Grid Grid.Row="0" Grid.Column="2" Margin="5,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                          x:Name="BatteryPlacer" Tag="8" PointerPressed="TooltipPlacer_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="10,1,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                            <TextBlock x:Uid="Main_Battery" x:Name="BatteryText" Text="Battery" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Run FontWeight="SemiBold" FontSize="18" x:Name="IndicatorsBatteryPercent" Text="70"/>
                                                <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">%</Run>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    <Grid Grid.Row="0" Grid.Column="3" Margin="5,0,10,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16" Background="{Binding ElementName=HiddenButton, Path=Background}" BorderBrush="{Binding ElementName=HiddenButton, Path=BorderBrush}" BorderThickness="{Binding ElementName=HiddenButton, Path=BorderThickness}"
                                          x:Name="VrmPlacer" Tag="7" PointerPressed="TooltipPlacer_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="10,1,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                            <TextBlock x:Uid="Main_MaxVrmCurrent" Text="VRM EDC" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Run FontWeight="SemiBold" FontSize="18" x:Name="IndicatorsVrmEdc" Text="30"/>
                                                <Run FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondary}">A</Run>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                <TextBlock Grid.Row="1" VerticalAlignment="Top" Margin="4,12,0,0" FontSize="17"
                                           x:Uid="Main_FrequentlyUsed" Text="Часто используемое"/>
                                <Grid Grid.Row="2" VerticalAlignment="Stretch" Margin="-10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition MaxHeight="75"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Margin="10,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Click="PresetsPage_Click" Tag="S">
                                        <Grid Margin="-10,-5,-5,-5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                                <TextBlock Margin="0,0,-20,0" x:Uid="Main_Preset" Text="Пресеты" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid Grid.Column="1" Margin="20,0,0,0">
                                                <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="25" Glyph="&#xeadf;"/>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Margin="5,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Click="OverclockPage_Click">
                                        <Grid Margin="-10,-5,-5,-5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                                <TextBlock Margin="0,0,-20,0" x:Uid="Main_OverclockPage" Text="Разгон" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                                <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="25" Glyph="&#xE945;"/>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="2" Margin="5,0,5,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Click="SettingsPage_Click">
                                        <Grid Margin="-10,-5,-5,-5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                                <TextBlock Margin="0,0,-25,0" x:Uid="Main_Settings" Text="Настройки" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                                <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="25" Glyph="&#xE713;"/>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="3" Margin="5,0,10,0" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" CornerRadius="16"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Click="FaqLink_Click">
                                        <Grid Margin="-10,-5,-5,-5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0" Orientation="Vertical">
                                                <TextBlock Margin="0,0,-20,0" x:Uid="Main_FaqPage" Text="Страница FAQ" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                                <FontIcon VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="25" Glyph="&#xE736;"/>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
            <Grid HorizontalAlignment="Stretch" Grid.Row="0" Grid.Column="1" CornerRadius="16" Margin="0,0,10,5" Shadow="{StaticResource SharedShadow}" Translation="0,0,20">
                <Grid CornerRadius="8" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition/>
                        </TransitionCollection>
                    </Grid.Transitions>
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition/>
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                    <TextBlock x:Uid="Main_OwnPresets" FontSize="17" Margin="14,16,0,0" Text="Пресеты"/>
                    <Grid Margin="0,42,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="55"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="0" x:Name="PresetPivot" Margin="-10,4,-1,22">
                            <StackPanel Orientation="Vertical" Margin="20,0,11,0"
                                        HorizontalAlignment="Stretch" IsHitTestVisible="True"
                                        x:Name="PresetCustom"/>
                        </ScrollViewer>
                        <Button Click="Apply_Click" x:Name="ApplyButton" Grid.Row="1" Margin="10,-22,10,10" 
                                CornerRadius="26" MinHeight="20" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}"
                                HorizontalContentAlignment="Stretch" VerticalAlignment="Stretch" 
                                Shadow="{ThemeResource SharedShadow}" Translation="0,0,20"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <ScaleTransform x:Name="ButtonScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Button.RenderTransform>
                            <Button.Resources>
                                <Storyboard x:Name="ButtonAnimationStoryboard">
                                    <!-- Анимация CornerRadius -->
                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ApplyButton" 
                                  Storyboard.TargetProperty="CornerRadius">
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="26"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.015" Value="25"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.03" Value="24"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.045" Value="23"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.06" Value="22"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.075" Value="21"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.09" Value="20"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.105" Value="19"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.12" Value="18"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.135" Value="17"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.15" Value="16"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.165" Value="17"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.18" Value="18"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.195" Value="19"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.21" Value="20"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.225" Value="21"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.24" Value="22"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.255" Value="23"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.27" Value="24"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.285" Value="25"/>
                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.30" Value="26"/>
                                    </ObjectAnimationUsingKeyFrames>
                                    <!-- Анимация Scale X -->
                                    <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                   Storyboard.TargetProperty="ScaleX"
                   From="1.0" To="1.02" Duration="0:0:0.15"
                   AutoReverse="True"/>
                                </Storyboard>
                            </Button.Resources>
                            <Grid Margin="-5,-5,-5,-5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <FontIcon Glyph="&#xE768;" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" x:Uid="Main_ApplyButton" 
           Text="Применить" FontWeight="SemiBold" FontSize="16" Margin="0,-1,0,0"/>
                                <FontIcon Glyph="&#xE76C;" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>