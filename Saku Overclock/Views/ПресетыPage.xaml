<Page
    x:Class="Saku_Overclock.Views.ПресетыPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="using:Saku_Overclock.Styles"
    xmlns:double="using:Saku_Overclock.Helpers"
    mc:Ignorable="d">
    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <double:DoubleToPercentConverter x:Key="DoubleToPercent" />
        <double:BooleanToFontWeightConverter x:Key="BooleanToWeight" />
        <Flyout x:Name="SymbolFlyout" Placement="Bottom">
            <!-- flyout content -->
            <GridView x:Name="SelectionGrid" IsItemClickEnabled="True">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="6" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.Resources>
                    <Style TargetType="Rectangle">
                        <Setter Property="Width" Value="40" />
                        <Setter Property="Height" Value="40" />
                        <Setter Property="RadiusX" Value="4" />
                        <Setter Property="RadiusY" Value="4" />
                    </Style>
                </GridView.Resources>
                <GridView.Items>
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xEcad;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeafc;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeb05;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe718;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe734;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeadf;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeb3c;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeb44;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xeb51;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xebd2;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xec32;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xec46;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xec48;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xec49;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xec4a;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xecc6;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe7ba;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xedad;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xee6f;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xee71;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xf211;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe945;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe9d9;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe9ca;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xe9ce;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xE706;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xE71A;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xE723;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xE733;" />
                    <FontIcon VerticalAlignment="Center" Margin="0,-10,0,0" HorizontalAlignment="Left" Glyph="&#xE82F;" />
                </GridView.Items>
            </GridView>
        </Flyout>
    </Page.Resources>
    <Grid Margin="-48,0,-50,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MaxWidth="1200">
        <Grid.RowDefinitions>
            <RowDefinition Height="147" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock x:Uid="Preset_Name" Text="Пресеты" FontSize="24" Margin="-1,-95,0,0" />

        <Button Click="AddPresetButton_Click" Margin="0,-85,-20,0" VerticalAlignment="Top" BorderBrush="Transparent"
                Background="Transparent" Grid.Row="0" CornerRadius="16"
                HorizontalAlignment="Right" Height="40" HorizontalContentAlignment="Stretch">
            <Button.RenderTransform>
                <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
            </Button.RenderTransform>
            <StackPanel Orientation="Horizontal" Margin="-5,-5,-5,-5" HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                <TextBlock FontSize="18" Margin="0,-1,0,0" x:Uid="Preset_SavedPresetsAddNew"
                           Text="Добавить " />
                <FontIcon Margin="7,0,0,0" Glyph="&#xE710;" HorizontalAlignment="Left"
                          VerticalAlignment="Center" />
            </StackPanel>
        </Button>
        <Grid Grid.Row="0" HorizontalAlignment="Stretch" Margin="0,-45,-22,0" CornerRadius="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1" Margin="17,-77,15,0" CornerRadius="8" HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <local:PresetSelector Height="115"
                                      SelectionChanged="PresetsControl_SelectionChanged"
                                      x:Name="PresetsControl" VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch" />
            </Grid>
            <Grid Grid.Column="0" VerticalAlignment="Top" Margin="1,0,16,7">
                <Grid CornerRadius="28" Height="110"
                      Shadow="{ThemeResource SharedShadow}"
                      Translation="0,0,20" VerticalAlignment="Stretch"
                      Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                      BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                      BorderThickness="1">
                    <Grid Margin="17,11,14,10" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Top" Orientation="Vertical">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="SelectedPresetTextsStackPanel" Grid.Column="0"
                                            VerticalAlignment="Top" Orientation="Vertical">
                                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Top"
                                               TextWrapping="Wrap" x:Name="SelectedPresetName"
                                               FontWeight="Medium" />
                                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Top"
                                               TextWrapping="Wrap" x:Name="SelectedPresetDescription"
                                               FontSize="14" Foreground="{ThemeResource TextFillColorSecondary}" />
                                    <StackPanel Margin="0,5,0,-5" Padding="3,0,3,0" Orientation="Horizontal">
                                        <Grid Background="{ThemeResource AccentColor}"
                                              CornerRadius="9" HorizontalAlignment="Left">
                                            <TextBlock Margin="5,0,5,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{ThemeResource DefaultFGColorAccentBrush}">
                                                dynPower
                                            </TextBlock>
                                        </Grid>
                                        <Border Margin="8,0,8,0"
                                                Background="{ThemeResource CircleElevationBorderBrush}"
                                                Width="1" Height="19" />
                                        <TextBlock FontWeight="SemiBold">
                                            <Run>TDP</Run>
                                            <Run Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                 x:Name="TdpValueSensorText">
                                                18
                                            </Run>
                                            <Run>/</Run>
                                            <Run x:Name="TdpLimitSensorText"
                                                 Text="20W" />
                                        </TextBlock>

                                        <TextBlock FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Top">
                                            <Run Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                 x:Name="CpuFreqSensorText" Text="5.5" />
                                        </TextBlock>
                                        <TextBlock Margin="10,0,0,0" FontWeight="SemiBold">
                                            <Run>CPU </Run>
                                            <Run x:Name="CpuTempSensorText"
                                                 Text="44C"
                                                 Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                        </TextBlock>
                                        <TextBlock Margin="10,0,0,0" x:Name="GpuTempSensorStackPanel"
                                                   FontWeight="SemiBold">
                                            <Run>GPU </Run>
                                            <Run x:Name="GpuTempSensorText" Text="37C"
                                                 Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,-13,-10"
                                            x:Name="EditCurrentButtonsStackPanel" HorizontalAlignment="Right"
                                            Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="EditPresetButton" Click="EditPresetButton_Click_1"
                                            BorderBrush="Transparent" Background="Transparent"
                                            VerticalAlignment="Center"
                                            CornerRadius="16" HorizontalAlignment="Right" Width="40" Height="40"
                                            HorizontalContentAlignment="Stretch">
                                        <Button.RenderTransform>
                                            <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
                                        </Button.RenderTransform>
                                        <Grid Margin="-5,-5,-5,-5" HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch">
                                            <FontIcon Margin="3,0,0,0" Glyph="&#xE70F;" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="0,-48,6,0">
            <ScrollViewer Margin="-1,-2,-11,0">
                <StackPanel Orientation="Vertical" Margin="2,0,13,0">
                    <StackPanel x:Name="PresetSettingsBeginnerView"
                                Orientation="Vertical">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                        <Grid PointerPressed="ToggleTheSwitchByTag" Tag="SmartTdp" CornerRadius="15,15,0,0"
                              Margin="0,0,0,0" Height="60" HorizontalAlignment="Stretch"
                              Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                            <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                          Glyph="&#xE9D2;" />
                                <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                           FontSize="14" Text="Умная оптимизация TDP" x:Uid="Preset_SmartTdp" />
                                <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondary}"
                                           Text="Автоматически подстраивать лимит мощности под активную задачу" />
                            </Grid>
                            <Border Height="32" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                    Background="{ThemeResource ControlElevationBorderBrush}"
                                    BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Shadow="{ThemeResource SharedShadow}"
                                    Translation="0,0,10">
                                <StackPanel Margin="0,-9,0,-9" Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <ToggleButton Background="Transparent"
                                                  BorderBrush="Transparent" CornerRadius="10"
                                                  Click="AutoTdpEnabled_OnClick"
                                                  x:Name="AutoTdpDisabled"
                                                  IsChecked="True">
                                        <TextBlock Margin="0,-2,0,-2" Text="Выкл"
                                                   x:Uid="Preset_AutoTdpDisabled" FontSize="14" x:Name="AutoTdpText1"
                                                   FontWeight="Medium" />
                                    </ToggleButton>
                                    <ToggleButton Background="Transparent"
                                                  BorderBrush="Transparent" CornerRadius="10"
                                                  Click="AutoTdpEnabled_OnClick"
                                                  x:Name="AutoTdpEnabled"
                                                  Margin="4,0,0,0">
                                        <TextBlock Margin="0,-2,0,-2" Text="Авто" FontSize="13"
                                                   x:Name="AutoTdpText2" x:Uid="Preset_AutoTdpEnabled"/>
                                    </ToggleButton>
                                    <ToggleButton Background="Transparent"
                                                  BorderBrush="Transparent" CornerRadius="10"
                                                  Click="AutoTdpEnabled_OnClick"
                                                  x:Name="AutoTdpManual"
                                                  Margin="4,0,0,0">
                                        <TextBlock Margin="0,-2,0,-2" Text="Ручное" FontSize="13"
                                                   x:Name="AutoTdpText3" x:Uid="Preset_AutoTdpManual"/>
                                    </ToggleButton>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Grid Margin="0,1,0,0" Height="50" HorizontalAlignment="Stretch" x:Name="PowerAdjustment"
                              Background="{ThemeResource ControlStrokeColorSecondaryBrush}" Visibility="Collapsed">
                            <StackPanel Margin="17,0,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
                                <FontIcon Glyph="&#xEB3C;" />
                                <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                           Text="Лимит TDP" x:Uid="Preset_TdpLimitText"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,17,0" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
                                <Slider Style="{ThemeResource FatSliderStyle}" x:Name="BaseTdpSlider"
                                        ValueChanged="BaseTdp_Slider_ValueChanged" Margin="40,0,0,0"
                                        VerticalAlignment="Top" Width="230" HorizontalAlignment="Left"
                                        Minimum="1" Maximum="40" Value="20" />
                                <NumberBox Minimum="1" ValueChanged="TargetNumberBox_ValueChanged" Height="33" Width="78" Margin="25,0,0,0"
                                           SmallChange="1" LargeChange="10" Tag="BaseTdpSlider" SpinButtonPlacementMode="Compact"
                                           Value="{Binding ElementName=BaseTdpSlider, Path=Value, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE950;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               Text="Улучшение iGPU" x:Uid="Preset_IgpuOptimization" FontSize="14"/>
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Preset_IgpuOptimizationDesc"/>
                                </Grid>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="190" SelectedIndex="0"
                                              x:Name="IntegratedGpuEnchantmentCombo" SelectionChanged="IntegratedGpuEnchantmentCombo_SelectionChanged"
                                              CornerRadius="15">
                                        <ComboBoxItem x:Uid="Preset_IgpuAuto" Content="Авто" />
                                        <ComboBoxItem x:Uid="Preset_IgpuStable" Content="Стабильное" />
                                        <ComboBoxItem x:Uid="Preset_IgpuMaxed" Content="Максимум" />
                                    </ComboBox>
                                </Grid>
                        </Grid>
                        <Grid Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                                  Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18"
                                              Glyph="&#xE847;" />
                                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                               Text="Усиление турбобуста" x:Uid="Preset_BetterTurbo" FontSize="14"/>
                                    <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondary}"
                                               x:Uid="Preset_BetterTurboDesc"/>
                                </Grid>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,1,17,0"
                                      Shadow="{StaticResource SharedShadow}" CornerRadius="15" Translation="0,0,20">
                                    <ComboBox Style="{ThemeResource AcrylicComboBoxStyle}" Width="190" SelectedIndex="0"
                                              x:Name="BetterTurboCombo" SelectionChanged="BetterTurboCombo_OnSelectionChanged"
                                              CornerRadius="15">
                                        <ComboBoxItem x:Uid="Preset_TurboAuto" Content="Авто" />
                                        <ComboBoxItem x:Uid="Preset_TurboSmart" Content="Умное" />
                                        <ComboBoxItem x:Uid="Preset_TurboHeavy" Content="Сильное" />
                                    </ComboBox>
                                </Grid>
                        </Grid>
                        <Grid x:Name="CurveOptimizerCustomGrid" Margin="0,-1,0,0"
                              HorizontalAlignment="Stretch" Background="Transparent"
                              PointerPressed="CurveOptimizerCustom_PointerPressed">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock Text="Андервольтинг" x:Uid="Preset_Undervolting"
                                           VerticalAlignment="Center" />
                                <FontIcon Margin="3,7,0,0" Glyph="&#xE9CE;"
                                          x:Uid="Preset_UndervoltingDesc">
                                    <FontIcon.RenderTransform>
                                        <ScaleTransform CenterX="15" CenterY="15" ScaleX="0.7"
                                                        ScaleY="0.7" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </StackPanel>
                            <ToggleSwitch HorizontalAlignment="Right" OffContent=""
                                          OnContent="" Margin="113,0,-113,0"
                                          x:Name="CurveOptimizerCustom"
                                          Toggled="CurveOptimizerCustom_Toggled" />
                        </Grid>
                        <Grid Margin="-15,0,-15,0"
                              Visibility="{Binding ElementName=CurveOptimizerCustom, Path=IsOn}">
                            <Slider
                                IsEnabled="{Binding ElementName=CurveOptimizerCustom, Path=IsOn}"
                                x:Name="CurveOptimizerLevelCustomSlider" Margin="35,0,35,0"
                                ValueChanged="CurveOptimizerLevelCustom_Slider_ValueChanged"
                                HorizontalAlignment="Stretch" Minimum="-50" Maximum="30"
                                Value="0" VerticalAlignment="Center" />
                        </Grid>
                        <Grid CornerRadius="0,0,15,15" PointerPressed="TryAdvancedButton_Click"
                              Margin="0,2,0,0" Height="60" HorizontalAlignment="Stretch"
                              Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                            <Grid HorizontalAlignment="Left" Height="35" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <FontIcon Grid.Row="0" HorizontalAlignment="Left" Margin="17,0,0,-18" Glyph="&#xE90F;" />
                                <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="50,-2,0,-2"
                                           Text="Расширенный режим" x:Uid="Preset_AdvancedMode"/>
                                <TextBlock Margin="50,2,0,-2" Grid.Row="1" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondary}" 
                                           x:Uid="Param_AdvancedModeDesc" Text="Точная настройка пресета" />
                            </Grid>
                            <Button VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"
                                    Shadow="{ThemeResource SharedShadow}" Translation="0,0,20" Width="190" x:Uid="Preset_AdvancedModeTry"
                                    Click="TryAdvancedButton_Click"
                                    CornerRadius="15" Content="Перейти"/>
                        </Grid>
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondary}"
                                   Margin="0,-1,0,0" FontSize="12"
                                   x:Uid="Preset_AppliedAllSettings"
                                   Text="Применяются все настройки пресета" />
                        <Border Background="Transparent" Height="77" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <TeachingTip Grid.Row="0" x:Name="ApplyTeach" IsOpen="False" />
        <Grid Grid.Row="1" Margin="0,0,23,10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="ApplyButton" Click="ApplyButton_Click" CornerRadius="16" Height="55"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Width="329"
                    VerticalAlignment="Stretch" Shadow="{ThemeResource SharedShadow}" Translation="0,0,20">
                <Grid Margin="-5,-5,-5,-5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <FontIcon Glyph="&#xE768;" HorizontalAlignment="Left" VerticalAlignment="Center"
                              Margin="10,0,0,0" />
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               x:Uid="Main_ApplyButton" Text="Применить" FontWeight="SemiBold"
                               FontSize="16" Margin="0,-1,0,0" />
                    <FontIcon Glyph="&#xE76C;" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,10,0" />
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>